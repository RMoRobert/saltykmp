<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{YYYY-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    <!-- INFO in production: the TRACE level emits a full routing trace for EVERY request, so a request
         flood (e.g. a login brute-force attempt) would pour megabytes into stdout — and Docker's default
         json-file log driver has no size cap, so that fills the host disk. Override with -Dlogback... or an
         env-specific config for debugging. -->
    <root level="info">
        <appender-ref ref="STDOUT"/>
    </root>
    <logger name="org.eclipse.jetty" level="INFO"/>
    <logger name="io.netty" level="INFO"/>
</configuration>